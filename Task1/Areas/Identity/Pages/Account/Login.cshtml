@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="identity-page-fill login-page-fill">
    <aside class="login-test-note-corner" aria-label="Test login credentials">
        <div class="sticky-note-login">
            <p class="sticky-note-title">Test data</p>
            <div class="sticky-note-section">
                <p class="sticky-note-role">Teacher</p>
                <p class="sticky-note-lines">Email: teacher1@sim.no<br />Password: Teacher1!</p>
            </div>
            <div class="sticky-note-section">
                <p class="sticky-note-role">Student</p>
                <p class="sticky-note-lines">Email: student1@sim.no<br />Password: Student1!</p>
            </div>
        </div>
    </aside>
    <div class="identity-page-inner">
        <div class="row justify-content-center">
            <div class="col-12 login-form-shell">
                <h1 class="text-center mb-4">@ViewData["Title"]</h1>
                <section class="text-start">
                    <form id="account" method="post">
                        <hr />
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="form-label">Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.Password" class="form-label">Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>
                        <div class="checkbox mb-3">
                            <label asp-for="Input.RememberMe" class="form-label">
                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                @Html.DisplayNameFor(m => m.Input.RememberMe)
                            </label>
                        </div>
                        <div>
                            <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Log in</button>
                        </div>
                    </form>
                    <p class="mt-3 mb-0 text-center">
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register</a>
                    </p>
                </section>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
