@model Assignment_4.Models.CaseFormViewModel

<input type="hidden" asp-for="Id" />

<div asp-validation-summary="All" class="text-danger"></div>

<div class="row g-2">
    <div class="col-md-6 mb-2">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="col-md-3 mb-2">
        <label asp-for="AgeYears" class="form-label"></label>
        <input asp-for="AgeYears" class="form-control" type="number" min="0" max="120" step="1" />
        <span asp-validation-for="AgeYears" class="text-danger"></span>
    </div>
    <div class="col-md-3 mb-2">
        <label asp-for="Sex" class="form-label"></label>
        <select asp-for="Sex" class="form-select">
            <option value="">— Select —</option>
            <option value="Female">Female</option>
            <option value="Male">Male</option>
            <option value="Other">Other</option>
        </select>
        <span asp-validation-for="Sex" class="text-danger"></span>
    </div>
    <div class="col-md-6 mb-2">
        <label asp-for="WeightKg" class="form-label"></label>
        <input asp-for="WeightKg" class="form-control" type="number" min="0" max="400" step="0.1" />
        <span asp-validation-for="WeightKg" class="text-danger"></span>
    </div>
    <div class="col-md-6 mb-2 d-flex align-items-end">
        <div class="form-check">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label"></label>
        </div>
    </div>
</div>

<h6 class="mt-3">Vitals</h6>
<div class="row g-2">
    <div class="col-6 col-md-4 mb-2">
        <label asp-for="SystolicBP" class="form-label"></label>
        <input asp-for="SystolicBP" class="form-control" type="number" min="0" max="400" step="0.1" />
    </div>
    <div class="col-6 col-md-4 mb-2">
        <label asp-for="DiastolicBP" class="form-label"></label>
        <input asp-for="DiastolicBP" class="form-control" type="number" min="0" max="300" step="0.1" />
    </div>
    <div class="col-6 col-md-4 mb-2">
        <label asp-for="HeartRate" class="form-label"></label>
        <input asp-for="HeartRate" class="form-control" type="number" min="0" max="300" step="0.1" />
    </div>
    <div class="col-6 col-md-4 mb-2">
        <label asp-for="RespiratoryRate" class="form-label"></label>
        <input asp-for="RespiratoryRate" class="form-control" type="number" min="0" max="120" step="0.1" />
    </div>
    <div class="col-6 col-md-4 mb-2">
        <label asp-for="OxygenSaturation" class="form-label"></label>
        <input asp-for="OxygenSaturation" class="form-control" type="number" min="0" max="100" step="0.1" />
    </div>
    <div class="col-6 col-md-4 mb-2">
        <label asp-for="Temperature" class="form-label"></label>
        <input asp-for="Temperature" class="form-control" type="number" min="30" max="45" step="0.1" />
    </div>
</div>

<h6 class="mt-3">Diagnoses</h6>
<div id="diagnosis-list" class="mb-2">
    @for (var i = 0; i < Model.Diagnoses.Count; i++)
    {
        <div class="input-group mb-1 clinical-row diagnosis-row">
            <input asp-for="Diagnoses[i]" class="form-control" />
            <button type="button" class="btn btn-outline-danger remove-clinical-row">Remove</button>
        </div>
    }
</div>
<button type="button" class="btn btn-sm btn-outline-secondary mb-3" id="add-diagnosis">Add diagnosis</button>

<h6 class="mt-3">Goals</h6>
<div id="goal-list" class="mb-2">
    @for (var i = 0; i < Model.Goals.Count; i++)
    {
        <div class="input-group mb-1 clinical-row goal-row">
            <input asp-for="Goals[i]" class="form-control" />
            <button type="button" class="btn btn-outline-danger remove-clinical-row">Remove</button>
        </div>
    }
</div>
<button type="button" class="btn btn-sm btn-outline-secondary mb-3" id="add-goal">Add goal</button>

<h6 class="mt-3">Allergies</h6>
<div id="allergy-list" class="mb-2">
    @for (var i = 0; i < Model.Allergies.Count; i++)
    {
        <div class="input-group mb-1 clinical-row allergy-row">
            <input asp-for="Allergies[i]" class="form-control" />
            <button type="button" class="btn btn-outline-danger remove-clinical-row">Remove</button>
        </div>
    }
</div>
<button type="button" class="btn btn-sm btn-outline-secondary mb-3" id="add-allergy">Add allergy</button>

<h6 class="mt-3">Medications</h6>
<div id="medication-list" class="mb-2">
    @for (var i = 0; i < Model.Medications.Count; i++)
    {
        <div class="row g-1 mb-2 clinical-row med-row align-items-end">
            <div class="col-md-5">
                <label class="form-label small mb-0">Name</label>
                <input asp-for="Medications[i].Name" class="form-control" data-med-name />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-0">Dosage</label>
                <input asp-for="Medications[i].Dosage" class="form-control" type="number" step="any" data-med-dose />
            </div>
            <div class="col-md-3">
                <label class="form-label small mb-0">Route</label>
                <input asp-for="Medications[i].Route" class="form-control" data-med-route />
            </div>
            <div class="col-md-2">
                <button type="button" class="btn btn-sm btn-outline-danger w-100 remove-med-row">Remove</button>
            </div>
        </div>
    }
</div>
<button type="button" class="btn btn-sm btn-outline-secondary mb-2" id="add-medication">Add medication</button>

<script>
(function () {
    function reindexDiagnoses() {
        document.querySelectorAll('#diagnosis-list .diagnosis-row').forEach(function (row, i) {
            var inp = row.querySelector('input');
            if (inp) inp.name = 'Diagnoses[' + i + ']';
        });
    }
    function reindexGoals() {
        document.querySelectorAll('#goal-list .goal-row').forEach(function (row, i) {
            var inp = row.querySelector('input');
            if (inp) inp.name = 'Goals[' + i + ']';
        });
    }
    function reindexAllergies() {
        document.querySelectorAll('#allergy-list .allergy-row').forEach(function (row, i) {
            var inp = row.querySelector('input');
            if (inp) inp.name = 'Allergies[' + i + ']';
        });
    }
    function reindexMeds() {
        document.querySelectorAll('#medication-list .med-row').forEach(function (row, i) {
            var n = row.querySelector('[data-med-name]');
            var d = row.querySelector('[data-med-dose]');
            var r = row.querySelector('[data-med-route]');
            if (n) n.name = 'Medications[' + i + '].Name';
            if (d) d.name = 'Medications[' + i + '].Dosage';
            if (r) r.name = 'Medications[' + i + '].Route';
        });
    }
    var form = document.querySelector('form');
    if (form) {
        form.addEventListener('submit', function () {
            reindexDiagnoses();
            reindexGoals();
            reindexAllergies();
            reindexMeds();
        });
    }
    document.getElementById('add-diagnosis')?.addEventListener('click', function () {
        var c = document.getElementById('diagnosis-list');
        var div = document.createElement('div');
        div.className = 'input-group mb-1 clinical-row diagnosis-row';
        div.innerHTML = '<input type="text" class="form-control" value="" /><button type="button" class="btn btn-outline-danger remove-clinical-row">Remove</button>';
        c.appendChild(div);
    });
    document.getElementById('add-goal')?.addEventListener('click', function () {
        var c = document.getElementById('goal-list');
        var div = document.createElement('div');
        div.className = 'input-group mb-1 clinical-row goal-row';
        div.innerHTML = '<input type="text" class="form-control" value="" /><button type="button" class="btn btn-outline-danger remove-clinical-row">Remove</button>';
        c.appendChild(div);
    });
    document.getElementById('add-allergy')?.addEventListener('click', function () {
        var c = document.getElementById('allergy-list');
        var div = document.createElement('div');
        div.className = 'input-group mb-1 clinical-row allergy-row';
        div.innerHTML = '<input type="text" class="form-control" value="" /><button type="button" class="btn btn-outline-danger remove-clinical-row">Remove</button>';
        c.appendChild(div);
    });
    document.getElementById('add-medication')?.addEventListener('click', function () {
        var c = document.getElementById('medication-list');
        var div = document.createElement('div');
        div.className = 'row g-1 mb-2 clinical-row med-row align-items-end';
        div.innerHTML = '<div class="col-md-5"><label class="form-label small mb-0">Name</label><input type="text" class="form-control" value="" data-med-name /></div>' +
            '<div class="col-md-2"><label class="form-label small mb-0">Dosage</label><input type="number" class="form-control" step="any" value="0" data-med-dose /></div>' +
            '<div class="col-md-3"><label class="form-label small mb-0">Route</label><input type="text" class="form-control" value="" data-med-route /></div>' +
            '<div class="col-md-2"><button type="button" class="btn btn-sm btn-outline-danger w-100 remove-med-row">Remove</button></div>';
        c.appendChild(div);
    });
    document.body.addEventListener('click', function (e) {
        if (e.target.closest('.remove-clinical-row')) {
            var row = e.target.closest('.diagnosis-row, .goal-row, .allergy-row');
            if (row && row.parentElement && row.parentElement.children.length > 1)
                row.remove();
        }
        if (e.target.closest('.remove-med-row')) {
            var mrow = e.target.closest('.med-row');
            if (mrow && mrow.parentElement && mrow.parentElement.children.length > 1)
                mrow.remove();
        }
    });
})();
</script>
