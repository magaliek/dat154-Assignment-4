@model Assignment_4.Models.CaseFormViewModel
@{
    ViewData["Title"] = "Create case";
}

<div class="cases-page-shell">
    <h1>Create case</h1>
    <form asp-action="Create" method="post">
        <partial name="_CaseFormFields" model="Model" />
        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Save case</button>
            <a asp-action="TeacherCases" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
