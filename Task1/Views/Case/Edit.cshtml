@model Assignment_4.Models.CaseFormViewModel
@{
    ViewData["Title"] = "Edit case";
}

<div class="cases-page-shell">
    <h1>Edit case</h1>
    <p class="text-muted small">Case id: @Model.Id</p>
    <form asp-action="Edit" method="post">
        <partial name="_CaseFormFields" model="Model" />
        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Save changes</button>
            <a asp-action="TeacherCases" class="btn btn-outline-secondary">Back to all cases</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
