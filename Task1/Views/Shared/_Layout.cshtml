<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Patient Journal</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Assignment_4.styles.css" asp-append-version="true" />
</head>
<body class="app-body">
    <header class="app-header">
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid app-edge-inset">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">Patient Journal</a>
                <div class="ms-auto">
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid app-edge-inset flex-grow-main">
        <main role="main" class="main-fill">
            @RenderBody()
        </main>
    </div>
    <footer class="site-footer flex-shrink-0 text-muted py-2">
        <div class="container-fluid app-edge-inset text-start">
            <small>&copy; 2026</small>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
