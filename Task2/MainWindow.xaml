<Window x:Class="Task2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simulation Interface" Height="800" Width="1200">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Login bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Student ID:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="StudentIdBox" Width="100" Margin="0,0,10,0"/>
            <Button x:Name="LoadCaseButton" Content="Load Case" Click="LoadCaseButton_Click"/>
        </StackPanel>

        <!-- Row 1: Patient header -->
        <Border Grid.Row="1" Background="#1a1a2e" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="PatientNameText" Text="No case loaded" 
                           Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,20,0"/>
                <TextBlock x:Name="PatientInfoText" Text="" 
                           Foreground="#aaaaaa" FontSize="14" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Row 2: Main content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Left column: vitals + intervention -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Vitals -->
                <GroupBox Grid.Row="0" Header="Vital Signs" Margin="0,0,0,10">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="5">
                            <TextBlock Text="Blood Pressure" FontWeight="Bold"/>
                            <TextBlock x:Name="BPText" Text="--/-- mmHg" FontSize="20"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="5">
                            <TextBlock Text="Heart Rate" FontWeight="Bold"/>
                            <TextBlock x:Name="HRText" Text="-- bpm" FontSize="20"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Grid.Row="0" Margin="5">
                            <TextBlock Text="SpO2" FontWeight="Bold"/>
                            <TextBlock x:Name="SpO2Text" Text="-- %" FontSize="20"/>
                        </StackPanel>
                        <StackPanel Grid.Column="0" Grid.Row="1" Margin="5">
                            <TextBlock Text="Respiratory Rate" FontWeight="Bold"/>
                            <TextBlock x:Name="RRText" Text="-- /min" FontSize="20"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="1" Margin="5">
                            <TextBlock Text="Temperature" FontWeight="Bold"/>
                            <TextBlock x:Name="TempText" Text="-- °C" FontSize="20"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Intervention form -->
                <GroupBox Grid.Row="1" Header="Register Intervention" Margin="0,0,0,10">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="5">
                            <TextBlock Text="Drug"/>
                            <ComboBox x:Name="DrugComboBox"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5">
                            <TextBlock Text="Dose (mg)"/>
                            <TextBox x:Name="DoseBox"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="5">
                            <TextBlock Text="Route"/>
                            <ComboBox x:Name="RouteComboBox">
                                <ComboBoxItem>IV</ComboBoxItem>
                                <ComboBoxItem>Oral</ComboBoxItem>
                                <ComboBoxItem>Subcutaneous</ComboBoxItem>
                                <ComboBoxItem>Sublingual</ComboBoxItem>
                                <ComboBoxItem>IM</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        <Button Grid.Column="3" Content="Register" 
                                VerticalAlignment="Bottom" Margin="5"
                                Click="RegisterIntervention_Click"/>
                    </Grid>
                </GroupBox>

                <!-- Event log -->
                <GroupBox Grid.Row="2" Header="Event Log">
                    <ListBox x:Name="EventLog" Margin="5"/>
                </GroupBox>
            </Grid>

            <!-- Right column: patient info -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="Allergies" Margin="0,0,0,5">
                    <ListBox x:Name="AllergiesList" Margin="5"/>
                </GroupBox>
                <GroupBox Grid.Row="1" Header="Medications" Margin="0,0,0,5">
                    <ListBox x:Name="MedicationsList" Margin="5"/>
                </GroupBox>
                <GroupBox Grid.Row="2" Header="Diagnoses">
                    <ListBox x:Name="DiagnosesList" Margin="5"/>
                </GroupBox>
            </Grid>
        </Grid>
    </Grid>
</Window>